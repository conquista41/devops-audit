# Copy this to .env and fill in your values
# Never commit .env to git!

APP_NAME="HealthCheck.dev"
DEBUG=true
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Local dev DB (matches docker-compose)
DATABASE_URL=postgresql+asyncpg://healthcheck:healthcheck_dev@localhost:5432/healthcheck

# Local Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# GitHub OAuth — create at https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

FRONTEND_URL=http://localhost:3000

# AWS (leave empty for local dev — S3 upload will be skipped)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_REPORTS=healthcheck-reports-dev

# Stripe (use test keys from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...

SES_FROM_EMAIL=noreply@healthcheck.dev
